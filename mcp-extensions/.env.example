# TaskEX MCP Extension Configuration
# =====================================

# Path to taskex.config.json (defaults to ./taskex.config.json if not set)
# TASKEX_CONFIG_PATH=C:\TaskEX_Ant\mcp-extensions\taskex.config.json

# Comma-separated BlueStacks ports (overrides config file)
# TASKEX_BLUESTACKS_PORTS=5555,5556

# Evony package name (overrides config file)
# TASKEX_EVONY_PACKAGE=com.topgamesinc.evony

# Evony activity name (overrides config file)
# TASKEX_EVONY_ACTIVITY=com.topgamesinc.androidplugin.UnityActivity
